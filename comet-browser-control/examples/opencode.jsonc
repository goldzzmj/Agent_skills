{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "comet-bridge": {
      "type": "local",
      "command": ["npx", "-y", "comet-mcp"],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "COMET_PATH": "C:\\Users\\GX\\AppData\\Local\\Perplexity\\Comet\\Application\\comet.exe"
      }
    }
  },
  "permission": {
    "skill": {
      "comet-browser-control": "allow"
    }
  }
}
